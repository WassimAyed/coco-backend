# =============================================================================
# Service B — userSecurityService
# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored; `.env.example` is committed as the template.
# Syntax: standard Java .properties (KEY=value, no quotes, no `export`).
# =============================================================================

# --- Server ---
SERVER_PORT=8090

# --- Database (MySQL) ---
# NOTE: project currently uses MySQL on port 3308 (not the default 3306).
DB_URL=jdbc:mysql://localhost:3308/CoCoUserDB?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=

# --- JWT signing ---
# Must be base64-encoded, at least 512 bits (64 bytes) for HS512.
# Generate locally with: openssl rand -base64 64
# IMPORTANT: rotate this secret when moving to staging/production —
# the placeholder default in application.properties has been in git history.
JWT_SECRET_KEY=PLACEHOLDER-replace-with-output-of-openssl-rand-base64-64
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Google OAuth2 ---
# Get these from Google Cloud Console > APIs & Services > Credentials.
# IMPORTANT: rotate the client secret — it has been committed previously.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- SMTP (Gmail) ---
# For Gmail use an app password, not your main password.
# IMPORTANT: rotate the app password — it has been committed previously.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# --- Frontend deep links ---
EMAIL_VERIFICATION_URL=http://localhost:4200/verify-email
TWO_FACTOR_VERIFICATION_URL=http://localhost:8090/index.html

# --- Storage gateway (MinIO via Node service) ---
STORAGE_BASE_URL=http://localhost:3000

# --- Eureka service discovery ---
# Service B is core auth and registers with Eureka by default.
# (Service A keeps EUREKA_ENABLED=false to make registration opt-in.)
EUREKA_ENABLED=true
EUREKA_DEFAULT_ZONE=http://localhost:6511/eureka/