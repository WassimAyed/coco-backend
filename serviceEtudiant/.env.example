# =============================================================================
# Service A — serviceEtudiant
# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored; `.env.example` is committed as the template.
# Syntax: standard Java .properties (KEY=value, no quotes, no `export`).
# =============================================================================

# --- Server ---
SERVER_PORT=8098

# --- Database (MySQL) ---
# NOTE: project currently uses MySQL on port 3308 (not the default 3306).
DB_URL=jdbc:mysql://localhost:3308/CoCoServiceEtudiantDB?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# --- Storage gateway (MinIO via Node service) ---
STORAGE_BASE_URL=http://localhost:3000

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- ML moderation service ---
# Set to empty string to disable automatic moderation
# (services stay PENDING for manual admin review).
ML_SERVICE_URL=http://localhost:8002

# --- Eureka service discovery ---
EUREKA_ENABLED=false
EUREKA_DEFAULT_ZONE=http://localhost:6511/eureka/